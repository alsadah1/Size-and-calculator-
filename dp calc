<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DP Transmitter Calculator & Diagram</title>
    <style>
        :root {
            --primary: #2da44e; /* GitHub Green */
            --bg: #f6f8fa; /* GitHub light gray */
            --border: #d0d7de;
            --text-main: #24292f;
            --info: #0969da; /* Active Blue */
        }
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
            padding: 15px; 
            max-width: 480px; 
            margin: 0 auto; 
            background-color: var(--bg);
            color: var(--text-main);
            line-height: 1.5;
        }
        h2, h3 { text-align: center; margin-top: 0; }
        h2 { font-size: 1.4rem; color: #1a1f23; }
        h3 { font-size: 1.1rem; color: #57606a; margin-bottom: 20px; }
        
        .card {
            background-color: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.08);
            border: 1px solid var(--border);
            margin-bottom: 20px;
        }

        /* Forms */
        label { display: block; margin-bottom: 6px; font-weight: 600; font-size: 0.95rem; color: #57606a; }
        select, input { 
            display: block; width: 100%; margin-bottom: 15px; padding: 12px; 
            box-sizing: border-box; border: 1px solid var(--border); border-radius: 6px; 
            font-size: 1rem; background-color: #fff;
        }
        select:focus, input:focus {
            outline: none; border-color: var(--info); box-shadow: 0 0 0 3px rgba(9,105,218,0.15);
        }

        /* SVG Diagram Style */
        .diagram-container {
            text-align: center; margin-bottom: 10px; padding: 10px;
            border: 1px dashed var(--border); border-radius: 6px; background-color: #fafbfc;
        }
        .tank-liquid { fill: rgba(9,105,218,0.15); }
        .tank-outline { stroke: #57606a; stroke-width: 2.5; fill: none; }
        .dp-tx-body { fill: #fff; stroke: #24292f; stroke-width: 2; }
        .dp-pipe { stroke: #24292f; stroke-width: 3; fill: none; }
        .vent-line { stroke: #57606a; stroke-width: 1.5; stroke-dasharray: 4; }
        .diag-text { font-size: 12px; font-weight: 600; fill: #24292f; }
        .diag-label-blue { fill: var(--info); font-weight: bold; }
        .diag-label-red { fill: #d73a49; font-weight: bold; }

        /* Formula & Live Display */
        .formula-section { font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace; font-size: 0.9rem; background-color: #fafbfc; padding: 15px; border-radius: 6px; border: 1px solid var(--border); margin-bottom: 15px; }
        .formula-display { text-align: center; font-size: 1.1rem; font-weight: bold; margin-top: 10px; color: var(--text-main); }
        .live-var { color: var(--info); border-bottom: 2px solid var(--info); padding: 0 2px; }
        .live-result { color: var(--primary); font-size: 1.3rem; }

        /* Results */
        .result-box { display: none; padding: 15px; background-color: #eaf5ff; border: 1px solid #b6e3ff; border-radius: 6px; text-align: center; margin-top: 10px;}
        .res-val { font-size: 1.25rem; font-weight: bold; }
        .res-lrv { color: #d73a49; }
        .res-urv { color: var(--primary); }
        
        button { 
            width: 100%; padding: 14px; background-color: var(--primary); color: white; 
            border: none; border-radius: 6px; font-size: 1.05rem; font-weight: 600; cursor: pointer; transition: background 0.1s;
        }
        button:hover { background-color: #2c974b; }
    </style>
</head>
<body>

    <div class="card">
        <h2>DP Level Calculator</h2>
        <h3>Atmospheric Tank</h3>

        <label for="tankType">Tank Configuration:</label>
        <select id="tankType">
            <option value="atmospheric">Atmospheric (Vented to Air)</option>
        </select>
        
        <label for="height">Max Liquid Height (mm):</label>
        <input type="number" id="height" placeholder="e.g., 5000" oninput="updateLiveFormula()">

        <label for="sg">Specific Gravity (SG):</label>
        <input type="number" id="sg" step="0.01" placeholder="e.g., 1.00" oninput="updateLiveFormula()">
    </div>

    <div class="card">
        <h3>System Diagram</h3>
        <div class="diagram-container">
            <!-- Embedded SVG Graphic -->
            <svg viewBox="0 0 320 380" width="100%" height="auto">
                
                <!-- Tank Outline (Atmospheric) -->
                <rect x="50" y="40" width="160" height="280" rx="10" ry="10" class="tank-outline" />
                
                <!-- Tank Liquid (Simulated level) -->
                <rect x="52.5" y="100" width="155" height="217.5" rx="8" ry="8" class="tank-liquid" id="diagLiquid" />
                
                <!-- Top Vent Graphic -->
                <line x1="130" y1="40" x2="130" y2="10" class="dp-pipe" />
                <line x1="115" y1="10" x2="145" y2="10" class="dp-pipe" />
                <text x="130" y="30" class="diag-text" text-anchor="middle">OPEN VENT</text>
                <text x="130" y="22" class="diag-text" text-anchor="middle">(To Atmosphere)</text>

                <!-- Level Labels -->
                <text x="215" y="315" class="diag-text" text-anchor="start">Tapping Point (0 mm)</text>
                <text x="215" y="105" class="diag-text" text-anchor="start" id="diagHeightLabel">Max Height</text>
                <line x1="210" y1="100" x2="50" y2="100" class="vent-line" />

                <!-- DP Transmitter Graphic -->
                <rect x="180" y="320" width="100" height="50" rx="5" ry="5" class="dp-tx-body" />
                <text x="230" y="340" class="diag-text" text-anchor="middle">DP Transmitter</text>
                
                <!-- Connections -->
                <circle cx="195" cy="345" r="5" class="dp-tx-body" stroke-dasharray="0" fill="white"/>
                <text x="195" y="360" class="diag-text diag-label-blue" text-anchor="middle">H</text>
                
                <circle cx="265" cy="345" r="5" class="dp-tx-body" stroke-dasharray="0" fill="white"/>
                <text x="265" y="360" class="diag-text diag-label-red" text-anchor="middle">L</text>

                <!-- Pipes/Vents -->
                <!-- High Side to Tank -->
                <path d="M 50 315 L 180 315 L 180 345 L 190 345" class="dp-pipe" />
                <text x="110" y="332" class="diag-text diag-label-blue" text-anchor="middle">Process Connection</text>
                
                <!-- Low Side to Atmosphere -->
                <path d="M 270 345 L 300 345 L 300 310" class="dp-pipe" />
                <line x1="285" y1="310" x2="315" y2="310" class="dp-pipe" />
                <text x="300" y="300" class="diag-text diag-label-red" text-anchor="middle">VENTED</text>
                <text x="300" y="290" class="diag-text diag-label-red" text-anchor="middle">(To Atmosphere)</text>

            </svg>
        </div>
    </div>

    <div class="card">
        <h3>Calculation Formula</h3>
        <div class="formula-section">
            <strong>Standard Formula (Atmospheric):</strong><br>
            DP Pressure = (Liquid Height) &times; (Specific Gravity)<br>
            <em>*Low side is vented, compensating for atmospheric pressure.</em>
        </div>

        <div class="formula-display">
            DP (URV) = <span class="live-var" id="liveH">H</span> mm &times; <span class="live-var" id="liveSG">SG</span><br>
            DP (URV) = <span class="live-result" id="liveResult">Result</span> mmH₂O
        </div>
    </div>

    <div class="card" style="text-align: center;">
        <button onclick="calculateRange()">Finalize & Show Range</button>

        <div class="result-box" id="output">
            <p><strong>Lower Range Value (LRV):</strong> <br><span id="lrv" class="res-val res-lrv"></span> mmH₂O</p>
            <p><strong>Upper Range Value (URV):</strong> <br><span id="urv" class="res-val res-urv"></span> mmH₂O</p>
        </div>
    </div>

    <script>
        // Set placeholders for live formula on load
        function updateLiveFormula() {
            var hInput = document.getElementById('height').value;
            var sgInput = document.getElementById('sg').value;
            var diagLiquid = document.getElementById('diagLiquid');
            var diagHeightLabel = document.getElementById('diagHeightLabel');

            // Handle height input display & simulation
            if (hInput === "" || isNaN(hInput) || parseFloat(hInput) <= 0) {
                document.getElementById('liveH').innerText = "H";
                diagLiquid.style.display = "none"; // Hide liquid simulation
                diagHeightLabel.innerText = "Max Height";
            } else {
                var h = parseFloat(hInput);
                document.getElementById('liveH').innerText = h.toFixed(0);
                
                // Simplified Diagram Simulation: adjust liquid rectangle
                diagLiquid.style.display = "block";
                diagHeightLabel.innerText = h.toFixed(0) + " mm";
            }

            // Handle SG input display
            if (sgInput === "" || isNaN(sgInput)) {
                document.getElementById('liveSg').innerText = "SG";
            } else {
                var sg = parseFloat(sgInput);
                document.getElementById('liveSG').innerText = sg.toFixed(2);
            }

            // Live Compensation Calculation (for display only)
            if (hInput !== "" && sgInput !== "" && !isNaN(hInput) && !isNaN(sgInput)) {
                var tempUrv = parseFloat(hInput) * parseFloat(sgInput);
                document.getElementById('liveResult').innerText = tempUrv.toFixed(2);
                document.getElementById('liveResult').style.color = "#2da44e"; // Green color when valid
            } else {
                document.getElementById('liveResult').innerText = "Result";
                document.getElementById('liveResult').style.color = "#24292f"; // Reset color
            }
        }

        // Final calculation and result display (Button trigger)
        function calculateRange() {
            var height = parseFloat(document.getElementById('height').value);
            var sg = parseFloat(document.getElementById('sg').value);

            if (!isNaN(height) && !isNaN(sg)) {
                var lrv = 0; // Standard for atmospheric tank withtapping at 0mm
                var urv = height * sg;

                document.getElementById('lrv').innerText = lrv.toFixed(2);
                document.getElementById('urv').innerText = urv.toFixed(2);
                
                document.getElementById('output').style.display = 'block';
            } else {
                alert("Please enter valid numbers for Height and Specific Gravity.");
                document.getElementById('output').style.display = 'none';
            }
        }

        // Initialize display on load
        updateLiveFormula();
    </script>

</body>
</html>
